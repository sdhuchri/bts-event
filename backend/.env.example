# ── AWS Bedrock (OCR) ──────────────────────────────────────────────
AWS_REGION=ap-southeast-3
# Vision-capable model / inference profile id yang aktif di region kamu.
# Contoh inference profile APAC untuk Claude (sesuaikan dgn yang tersedia di akunmu):
#   apac.anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MODEL_ID=apac.anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_ACCESS_KEY_ID=isi_access_key_kamu
AWS_SECRET_ACCESS_KEY=isi_secret_access_key_kamu
# Opsional, hanya jika pakai temporary credentials (STS):
# AWS_SESSION_TOKEN=

# ── Upload / OCR ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
# Sisi terpanjang gambar setelah resize sebelum dikirim ke Bedrock (hemat token).
MAX_IMAGE_DIMENSION=1600

# ── Database (Postgres bersama, instance nalarx-dashboard) ──────────
# Dari dalam container backend, host Postgres = host.docker.internal.
DATABASE_URL=postgresql+asyncpg://nalarx:nalarx_secret@host.docker.internal:5432/bts_event

# ── API publik untuk native mobile app (X-API-Key) ─────────────────
# Boleh lebih dari satu key (dipisah koma) untuk rotasi / multi-app.
EXT_API_KEYS=ganti-dengan-secret-acak-kuat

# ── WhatsApp gateway (Baileys) untuk OTP ───────────────────────────
WA_GATEWAY_URL=http://wa-gateway:3000
WA_GATEWAY_API_KEY=ganti-dengan-secret-yang-sama-di-wa-gateway
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# ── CORS ───────────────────────────────────────────────────────────
# Frontend Next.js berjalan di port 3002 (3000 dipakai project lain).
CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002
